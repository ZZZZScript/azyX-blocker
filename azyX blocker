local function createPlatform(size, color, name)
    local hrp = getHRP()
    if not hrp then return end
    
    local platform = Instance.new("Part")
    platform.Size = Vector3.new(size, 0.5, size)
    platform.Position = hrp.Position - Vector3.new(0, 3, 0)
    platform.Anchored = true
    platform.CanCollide = true
    platform.Transparency = 0.2
    platform.Material = Enum.Material.Neon
    platform.Color = color
    platform.Name = "EventPlatform_" .. name
    platform.Parent = workspace
    
    local selectionBox = Instance.new("SelectionBox")
    selectionBox.Adornee = platform
    selectionBox.Color3 = color
    selectionBox.LineThickness = 0.08
    selectionBox.Transparency = 0.3
    selectionBox.Parent = platform
    
    table.insert(eventPlatforms, platform)
    Debris:AddItem(platform, 30)
    print("[ASCEND] " .. name .. " criada! (" .. size .. "x" .. size .. ")")
end

local function clearEventPlatforms()
    for _, plat in ipairs(eventPlatforms) do
        pcall(function() plat:Destroy() end)
    end
    eventPlatforms = {}
    
    if flyingPlatform then
        pcall(function() flyingPlatform:Destroy() end)
        flyingPlatform = nil
