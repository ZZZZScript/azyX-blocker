local wsDragging = false
local function updateWalkSpeed(value)
    local newVal = math.clamp(value, 16, 50)
    local percent = (newVal - 16) / (50 - 16)
    wsFill.Size = UDim2.new(percent, 0, 1, 0)
    wsKnob.Position = UDim2.new(percent, -8, 0.5, -8)
    wsValue.Text = tostring(math.floor(newVal))
    WalkSpeedValue = newVal
    local hum = getHumanoid()
    if hum then hum.WalkSpeed = newVal end
end

wsKnob.MouseButton1Down:Connect(function() wsDragging = true end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then wsDragging = false end
end)
UserInputService.InputChanged:Connect(function(input)
    if wsDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local mp = UserInputService:GetMouseLocation()
        local rp = mp.X - wsKnob.AbsolutePosition.X
        local tw = wsBg.AbsoluteSize.X
        local p = math.clamp(rp / tw, 0, 1)
        updateWalkSpeed(16 + p * (50 - 16))
    end
end)
updateWalkSpeed(16)

