    label.TextSize = 11
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame
    
    local toggleBtn = Instance.new("TextButton")
    toggleBtn.Size = UDim2.new(0, 46, 0, 24)
    toggleBtn.Position = UDim2.new(1, -58, 0.5, -12)
    toggleBtn.BackgroundColor3 = default and Colors.Accent or Colors.Background
    toggleBtn.Text = ""
    toggleBtn.Parent = frame
    createUICorner(toggleBtn, 12)
    
    local indicator = Instance.new("Frame")
    indicator.Size = UDim2.new(0, 20, 0, 20)
    indicator.Position = default and UDim2.new(1, -24, 0.5, -10) or UDim2.new(0, 4, 0.5, -10)
    indicator.BackgroundColor3 = Colors.Text
    indicator.Parent = toggleBtn
    createUICorner(indicator, 10)
    
    local active = default
    toggleBtn.MouseButton1Click:Connect(function()
        active = not active
        toggleBtn.BackgroundColor3 = active and Colors.Accent or Colors.Background
        indicator.Position = active and UDim2.new(1, -24, 0.5, -10) or UDim2.new(0, 4, 0.5, -10)
        if callback then callback(active) end
    end)
    return frame
end

