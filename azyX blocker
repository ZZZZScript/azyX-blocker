-- // 2 (Gold Stroke Gradient Helper) //
local function goldStrokeGradient()
	return ColorSequence.new({
		ColorSequenceKeypoint.new(0, BLACK),
		ColorSequenceKeypoint.new(0.5, GOLD),
		ColorSequenceKeypoint.new(1, BLACK)
	})
end

local function addGoldStroke(parent, thickness)
	local st = Instance.new("UIStroke", parent)
	st.Color = WHITE
	st.Thickness = thickness or 1.5
	st.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	local g = Instance.new("UIGradient", st)
	g.Color = goldStrokeGradient()
	return st, g
end

