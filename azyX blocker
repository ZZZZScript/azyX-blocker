-- Decorative moving dots (reduced from 60+ to ~20 for performance)
local particles = {}
local particlePositions = {
    {0.36, 0.45}, {0.44, 0.97}, {0.18, 0.36}, {0.90, 0.72},
    {0.52, 0.01}, {0.29, 0.68}, {0.31, 0.19}, {0.51, 0.30},
    {0.74, 0.66}, {0.25, 0.62}, {0.80, 0.10}, {0.56, 0.26},
    {0.47, 0.99}, {0.10, 0.46}, {0.91, 0.87}, {0.50, 0.30},
    {0.21, 0.65}, {0.03, 0.80}, {0.62, 0.58}, {0.45, 0.58}
}

for i, pos in ipairs(particlePositions) do
    local dot = Instance.new("Frame")
    dot.Size               = UDim2.new(0, 4, 0, 4)
    dot.Position           = UDim2.new(pos[1], 0, pos[2], 0)
    dot.BackgroundColor3   = Color3.fromRGB(255, 255, 255)
    dot.BackgroundTransparency = 0.6
    dot.BorderSizePixel    = 0
    dot.Parent             = mainFrame

    local dotCorner = Instance.new("UICorner")
    dotCorner.CornerRadius = UDim.new(1, 0)
    dotCorner.Parent = dot

    table.insert(particles, {frame = dot, baseX = pos[1], baseY = pos[2], vx = math.random(-4,4)/10000, vy = math.random(-4,4)/10000})
end

-- Animate particles gently (much lighter than original)
RunService.RenderStepped:Connect(function(delta)
    for _, p in ipairs(particles) do
        local f = p.frame
        local x = p.baseX + math.sin(tick() * 2 + p.baseX * 10) * 0.008
        local y = p.baseY + math.cos(tick() * 2 + p.baseY * 10) * 0.008
        x = math.clamp(x, 0, 1)
        y = math.clamp(y, 0, 1)
        f.Position = UDim2.new(x, 0, y, 0)
    end
end)

